# Environment variables configuration

# Database URL (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/talktodata

# Or use SQLite for simpler setup (uncomment and comment PostgreSQL above)
# DATABASE_URL=sqlite:///./talktodata.db

# LLM Provider Selection (gemini or ollama)
LLM_PROVIDER=gemini

# Google Gemini API Key (for gemini provider)
GEMINI_API_KEY=AIzaSyBeEMeDPGacRbfyAVcc6enqyduv50H1qO4

# Ollama Configuration (for ollama provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# Application Settings
DEBUG=true
